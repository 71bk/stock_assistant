# AI Worker 環境變數範本
# 複製此檔案為 .env 並填入實際值

# ============================================================
# LLM 供應商選擇 (openai / ollama / gemini)
# ============================================================
# 預設使用 ollama (免費本地運行)
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=
OCR_PROVIDER=auto

# ============================================================
# Ollama 設定 (免費 & 本地運行)
# 下載: https://ollama.com/download
# 安裝後執行: ollama pull llama3.2-vision
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=llama3.2-vision
OLLAMA_TEXT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ============================================================
# Google Gemini 設定 (有免費額度)
# 取得 API Key: https://aistudio.google.com/apikey
# ============================================================
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-1.5-flash
GEMINI_TEXT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ============================================================
# OpenAI 設定 (付費)
# ============================================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# Database (PostgreSQL + pgvector)
# ============================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invest_dev

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# Service Config
# ============================================================
SERVICE_NAME=ai-worker
ENVIRONMENT=dev
LOG_LEVEL=INFO

# CORS 允許的來源 (逗號分隔)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# OCR 設定
# ============================================================
# Tesseract 路徑（Windows 通常需要設定，留空使用 PATH 環境變數）
TESSERACT_PATH=

# OCR 品質閾值（低於此值時使用 Vision LLM 備援）
OCR_MIN_CONFIDENCE=0.5
OCR_MIN_TEXT_LENGTH=20

# 是否啟用 Vision LLM 備援
OCR_FALLBACK_TO_VISION=true

# Embedding (must match DB vector dimension)
EMBEDDING_DIMENSION=1536
EMBEDDING_EXPECTED_DIMENSION=1536

# ============================================================
# RAG Ingestion Limits
# ============================================================
RAG_DOWNLOAD_MAX_BYTES=52428800
RAG_DOWNLOAD_TIMEOUT_TOTAL=60
RAG_DOWNLOAD_TIMEOUT_CONNECT=3
RAG_DOWNLOAD_TIMEOUT_READ=30

# ============================================================
# PDF Parsing Limits
# ============================================================
PDF_MAX_PAGES=50
PDF_MAX_TOTAL_PIXELS=200000000
