# Copy this file to .env.prod on the server. Do not commit real secrets.

COMPOSE_PROJECT_NAME=stock-assistant-prod

# Public domains
APP_DOMAIN=https://app.stock.71bk.dev
API_DOMAIN=https://api.stock.71bk.dev

# Images published by GitHub Actions
BACKEND_IMAGE=ghcr.io/71bk/stock_assistant/backend:latest
AI_WORKER_IMAGE=ghcr.io/71bk/stock_assistant/ai-worker:latest

# Docker network
APP_DOCKER_SUBNET=172.30.0.0/24
NGINX_INTERNAL_IP=172.30.0.10
# nginx is published on 127.0.0.1 only (public traffic comes via the tunnel)
NGINX_HTTP_PORT=80

# Cloudflare Tunnel token (Zero Trust > Networks > Tunnels > create > token).
# In the tunnel's public hostname, route api.stock.71bk.dev -> http://nginx:80
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# PostgreSQL
POSTGRES_DB=invest_assistant
POSTGRES_USER=invest
POSTGRES_PASSWORD=replace-with-strong-password
DB_POOL_SIZE=10

# Backend auth / security
APP_AUTH_JWT_SECRET=replace-with-at-least-32-random-bytes
APP_AUTH_ISSUER=invest-assistant
APP_AUTH_LOGIN_REDIRECT=https://app.stock.71bk.dev
APP_CORS_ORIGINS=https://app.stock.71bk.dev
APP_RATE_LIMIT_PROVIDER=redis
APP_RATE_LIMIT_REDIS_FAIL_OPEN=false

# Google OAuth. Set these only if Google login is enabled.
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=

# Admin API / bootstrap
APP_ADMIN_API_KEY=
APP_ADMIN_BOOTSTRAP_ENABLED=false
APP_ADMIN_BOOTSTRAP_EMAIL=
APP_ADMIN_BOOTSTRAP_PASSWORD=
APP_ADMIN_BOOTSTRAP_DISPLAY_NAME=Admin
APP_ADMIN_BOOTSTRAP_UPDATE_PASSWORD=false

# Monitoring (Prometheus + Grafana)
PROMETHEUS_RETENTION_TIME=30d
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password
GRAFANA_PORT=3000
GRAFANA_ROOT_URL=http://localhost:3000
# Slack incoming webhook URL for metric alerts (Grafana contact point).
SLACK_WEBHOOK_PROD=

# Sentry (backend). DSN has a built-in default; override per environment if needed.
# Keep PII off unless your privacy policy allows it.
SENTRY_DSN=
SENTRY_SEND_DEFAULT_PII=false

# Backend AI assistant
APP_AI_GROQ_BASE_URL=https://api.groq.com/openai/v1
APP_AI_GROQ_API_KEY=replace-with-groq-api-key
APP_AI_GROQ_MODEL=openai/gpt-oss-120b

# File upload limits
APP_RAG_MAX_FILE_SIZE_MB=50
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=50MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=50MB

# AI worker / OCR / RAG
AI_WORKER_LOG_LEVEL=INFO
AI_WORKER_CORS_ORIGINS=https://app.stock.71bk.dev,https://api.stock.71bk.dev
AI_WORKER_LLM_PROVIDER=gemini
AI_WORKER_EMBEDDING_PROVIDER=gemini
AI_WORKER_OCR_PROVIDER=gemini
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
AI_WORKER_EMBEDDING_DIMENSION=1536
AI_WORKER_EMBEDDING_EXPECTED_DIMENSION=1536
RAG_DOWNLOAD_MAX_BYTES=52428800
PDF_MAX_PAGES=50
PDF_MAX_TOTAL_PIXELS=200000000

# Optional stock market providers
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
FUGLE_API_KEY=

# Database backups (db-backup service). Local rotation always runs; Cloudflare R2
# upload is enabled only when R2_ACCESS_KEY_ID/R2_ENDPOINT/R2_BUCKET are all set.
BACKUP_TZ=Asia/Taipei
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP_DAYS=7
R2_KEEP_DAYS=30
# Cloudflare dashboard: R2 > Manage R2 API Tokens > create token (Object Read & Write).
# Endpoint is https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=
R2_PREFIX=postgres
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
