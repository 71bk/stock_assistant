# Backend environment variables (AI / Groq)
APP_AI_GROQ_BASE_URL=https://api.groq.com/openai/v1
APP_AI_GROQ_API_KEY=
APP_AI_GROQ_MODEL=openai/gpt-oss-120b
APP_AI_GROQ_TEMPERATURE=0.2
APP_AI_GROQ_MAX_TOKENS=1024
APP_AI_GROQ_TOP_P=1.0
APP_AI_GROQ_TIMEOUT_SECONDS=120
APP_OCR_AI_WORKER_BASE_URL=http://localhost:8001
APP_RAG_AI_WORKER_BASE_URL=http://localhost:8001
APP_RAG_MAX_FILE_SIZE_MB=50
APP_RAG_SNAPSHOT_ENABLED=false
APP_RAG_SNAPSHOT_CRON=0 30 2 * * *
APP_AI_CHAT_INSTRUMENT_SEARCH_ENABLED=true
APP_AI_CHAT_INSTRUMENT_SEARCH_LIMIT=10
APP_AI_CHAT_INSTRUMENT_SEARCH_CACHE_TTL=5m
APP_AI_CHAT_INSTRUMENT_SEARCH_CACHE_STATS_INTERVAL=5m
APP_AI_CHAT_QUOTE_SEARCH_ENABLED=true
APP_AI_CHAT_QUOTE_SEARCH_KEYWORDS=價格,股價,多少,現價,收盤,漲跌,報價,quote,price
